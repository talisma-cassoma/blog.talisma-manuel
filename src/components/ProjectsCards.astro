---
import ProjectCard from "./ProjectCard.astro";

import { Icon } from "astro-icon/components";

interface Project {
    title: string;
    previewImage: string;
    postImage: string;
    desc: string;
    url: string;
    badge: string[];
    githubRepo: string;
    stack: string[];
    icon?: string;
}


const projects: Project[] = [
    {
        title: "PCB Defects Recognition",
        previewImage: "/pcb_defects_recognition_proj_thumb.webp",
        postImage: "/pcb_defects_recognition_proj_thumb.webp",
        desc: "Automates printed circuit board defect detection using computer vision and deep learning.",
        url: "https://github.com/talisma-cassoma/pcb-components-detection-recognition",
        githubRepo: "talisma-cassoma/pcb-components-detection-recognition",
        badge: ["Computer Vision", "Deep Learning"],
        stack: ["devicon-plain:python", "devicon-plain:opencv", "simple-icons:pytorch", "simple-icons:tensorflow"],
        icon: "mdi:led-on",
    },
    {
        title: "AI Plant Assistant",
        previewImage: "/plant_disease_detection_proj_thumb.webp",
        postImage: "/plant_disease_detection_proj_thumb.webp",
        desc: "An end-to-end strategy for training and automatically deploying plant disease detection AI models.",
        url: "/blog/building-my-ai-plant-assistant-an-e2e-journey",
        githubRepo: "talisma-cassoma/ai-plant-assistant",
        badge: ["Mobile", "Machine Learning"],
        stack: ["devicon-plain:python", "devicon-plain:opencv", "tabler:brand-react-native"],
        icon: "tabler:plant",
    },
    {
        title: "Underwater Drone Vision System",
        previewImage: "/doceanlab_proj_thumb.webp",
        postImage: "/doceanlab_proj_thumb.webp",
        desc: "An underwater research drone that films and recognizes marine species using deep learning.",
        url: "https://github.com/talisma-cassoma/UnderWaterDrone-D-OceanLab",
        badge: ["Mechanical", "Computer Vision"],
        githubRepo: "talisma-cassoma/UnderWaterDrone-D-OceanLab",
        icon: "tabler:drone",
        stack: ["devicon-plain:python"],
    },
];

async function getGithubStats(repo: string) {
    const res = await fetch(`https://api.github.com/repos/${repo}`);

    if (!res.ok) {
        console.error(`Error fetching GitHub stats for ${repo}: ${res.status}`);
        return null;
    }

    const data = await res.json();
    console.log(
        `GitHub stats for ${repo}: ${data.stargazers_count} stars, ${data.forks_count} forks`,
    );

    return {
        stars: data.stargazers_count,
        forks: data.forks_count,
    };
}

// Apenas as exceções onde o Devicon falha ou você prefere outro pacote
const techExceptions: Record<string, string> = {
    react: "mdi:react", // nao existe no devicon, então usei mdi
    reactnative: "tabler:brand-react-native",
    tensorflow: "simple-icons:tensorflow",
    pytorch: "simple-icons:pytorch",
};
---

<section
  class="flex flex-col gap-4 overflow-hidden py-12 animate-hero-stagger
         md:py-16
         lg:flex-row lg:gap-4 lg:py-20"
>
    <!-- Left Side -->
    <div
        class="flex flex-col w-full
               lg:sticky lg:top-24 lg:w-80 lg:h-fit"
    >
        <p
            class="text-xs font-semibold uppercase tracking-[0.2em] text-accent
                   sm:text-sm
                   lg:text-center"
        >
            Open Source Projects
        </p>

        <h2
            class="mt-4 text-3xl font-bold tracking-tight leading-tight
                   sm:text-4xl
                   lg:text-center lg:text-5xl"
        >
            Some of my projects that I've worked on
        </h2>

        <p
            class="mt-6 text-base leading-relaxed text-foreground-muted
                   sm:text-lg
                   lg:text-center"
        >
            Featured open-source projects showcasing end-to-end development —
            from embedded firmware to full-stack applications.
        </p>

        <div class="flex flex-col mt-8 justify-center">
            <a
                href="/projects"
                class="btn w-full bg-[--color-green-200] border-2 text-white hover:bg-emerald-500
                       sm:w-56
                       lg:mx-auto"
            >
                View more

                <Icon
                    name="tabler:arrow-narrow-right"
                    class="w-5 h-5"
                />
            </a>
        </div>
    </div>

    <!-- Cards -->
    <div class="flex flex-col flex-1 gap-6 md:gap-8">
        {
            await Promise.all(
                projects.map(async (project, index) => {
                    const stats = await getGithubStats(project.githubRepo);

                    return (
                        <ProjectCard
                            index={index}
                            title={project.title}
                            description={project.desc}
                            tags={project.badge}
                            icon={project.icon}
                            stats={stats}
                            stack={project.stack}
                            previewImage={project.previewImage}
                            url={project.url}
                        />
                    );
                }),
            )
        }
    </div>
</section>
