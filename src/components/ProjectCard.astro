---
import { Icon } from "astro-icon/components";

export interface ProjectCardProps {
    index: number;
    title: string;
    description: string;
    tags: string[];
    icon: string;
    stats?: {
        stars: number;
        forks: number;
    };
    stack: string[];
    previewImage: string;
    url: string;
}

const { index, title, description, tags, icon, stats, stack, previewImage, url } =
    Astro.props as ProjectCardProps;

console.log(`ProjectCard stats for ${title}:`, stats);
---

<a
    href={url}
    class="group flex gap-4 rounded-3xl bg-[#f1efefe6] p-4 transition-all duration-500 dark:bg-[#242c35] sm:p-6 "
    data-reveal data-reveal-delay=`${index + 1}`
>
    <!-- Left column -->
    <div class="flex w-16 shrink-0 flex-col items-center gap-3">
        <div
            class="flex h-11 w-11 items-center justify-center rounded-2xl bg-emerald-500 text-white"
        >
            <Icon name={icon} size={24} />
        </div>
    </div>

    <!-- Content -->
    <div class="min-w-72 flex-1 flex flex-col gap-4">
        <!-- Title / Description / Preview -->
        <div class="relative h-content rounded-[.8rem] overflow-hidden">
            <!-- TEXT -->
            <div
                class="sticky flex flex-col box-border gap-2 top-0 transition-all duration-500 group-hover:opacity-0 group-hover:-translate-y-3"
            >
                <h3
                    class="text-lg font-semibold dark:text-white sm:text-xl lg:text-2xl"
                >
                    {title}
                </h3>

                <p
                    class="text-sm leading-6 text-foreground-muted sm:text-base"
                >
                    {description}
                </p>
               
                
            </div>

            <!-- IMAGE -->
            <div
                class="absolute inset-0 overflow-hidden opacity-0 box-border transition-all duration-500 group-hover:opacity-100"
            >
                <img
                    src={previewImage}
                    alt={title}
                    class="size-auto grayscale transition duration-500 group-hover:scale-105 group-hover:grayscale-0"
                />
            </div>
        </div>
         <!-- Tags -->
                {
                    tags?.length > 0 && (
                        <ul class="flex flex-wrap gap-2">
                            {tags.map((tag) => (
                                <li class="rounded-3xl bg-white px-3 py-1 text-xs opacity-75 dark:bg-[#1d232a] sm:text-sm">
                                    {tag}
                                </li>
                            ))}
                        </ul>
                    )
                }
        <div class="flex items-center justify-between">
                    <!-- Stack -->
                    {
                        stack?.length > 0 && (
                            <ul class="flex flex-wrap gap-2">
                                {stack.map((stack) => (
                                    <Icon
                                        name={stack}
                                        class="h-4 w-4 text-[#00B37E]"
                                        title={stack}
                                    />
                                ))}
                            </ul>
                        )
                    }
                    <div class="flex gap-1 text-xs font-medium">
                        <span
                            class="flex items-center justify-center gap-1 rounded-md px-2 py-1"
                        >
                            {stats?.stars}
                            <Icon name="tabler:star" size={12} />
                        </span>

                        <span
                            class="flex items-center justify-center gap-1 rounded-md px-2 py-1"
                        >
                            {stats?.forks}
                            <Icon name="tabler:git-fork" size={12} />
                        </span>
                    </div>
                </div>
    </div>
</a>
